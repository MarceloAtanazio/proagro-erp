# ============================================================
# ProAgro ERP — Variáveis de ambiente
# Copie este arquivo para ".env" (uso local) e configure os
# mesmos valores em Vercel > Project Settings > Environment Variables
# ============================================================

# Connection string do Supabase (Project Settings > Database > Connection string)
# IMPORTANTE: use o modo "Transaction pooler" (porta 6543), recomendado
# para funções serverless — evita esgotar conexões diretas do Postgres.
# Formato: postgresql://postgres.[ref]:[SUA-SENHA]@aws-0-[região].pooler.supabase.com:6543/postgres
DATABASE_URL=

# String aleatória longa usada para assinar os cookies de sessão (JWT).
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Ambiente (deixe "production" na Vercel; pode ficar em branco localmente)
NODE_ENV=
